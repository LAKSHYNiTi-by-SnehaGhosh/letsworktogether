generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Users & Auth
// ------------------------------------------------------

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id           String    @id
  email        String    @unique
  passwordHash String?   @map("password_hash")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  subscriptionPlan   SubscriptionPlan @default(FREE) @map("subscription_plan")
  aiTotalLimit       Int       @default(50) @map("ai_total_limit")
  aiUsageCount       Int       @default(0) @map("ai_usage_count")
  aiUsageResetDate   DateTime? @map("ai_usage_reset_date")

  profile            Profile?
  sessions        Session[]
  memberships     OrganizationMember[]
  teamMemberships TeamMember[]
  projectMemberships ProjectMember[]
  assignedTasks   Task[]
  submissions     TaskSubmission[]
  comments        Comment[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  apiKeys         ApiKey[]
  attachments     Attachment[]
  documents       Document[]
  aiUsageLogs     AIUsageLog[]
  aiMemories      AIPersonaMemory[]

  // New relations
  subscription    Subscription?
  mentorProfile   MentorProfile?
  mentorRequests  MentorRequest[] @relation("StudentRequests")
  mentorReviews   MentorReview[]  @relation("StudentReviews")
  mentorTransactions MentorTransaction[] @relation("StudentTransactions")
  sentInvitations OrganizationInvitation[] @relation("SentInvitations")

  @@map("users")
}

model Profile {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id")
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  avatarUrl String?   @map("avatar_url")
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model ApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  key            String    @unique
  name           String
  userId         String?   @map("user_id")
  organizationId String?   @map("organization_id") @db.Uuid
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@map("api_keys")
}

// ------------------------------------------------------
// Organizations & Multi-Tenancy
// ------------------------------------------------------

model Organization {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  billingEmail String?   @map("billing_email")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  members      OrganizationMember[]
  invitations  OrganizationInvitation[]
  teams        Team[]
  roles        Role[]
  projects     Project[]
  clients      Client[]
  apiKeys      ApiKey[]
  activityLogs ActivityLog[]

  @@map("organizations")
}

model OrganizationMember {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id")
  roleId         String    @map("role_id") @db.Uuid
  joinedAt       DateTime  @default(now()) @map("joined_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationInvitation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String
  roleId         String?   @map("role_id") @db.Uuid
  roleName       String    @default("MEMBER") @map("role_name")
  token          String    @unique
  invitedById    String    @map("invited_by_id")
  status         String    @default("PENDING")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@map("organization_invitations")
}

model Team {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  projects     Project[]

  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String    @id @default(uuid()) @db.Uuid
  teamId    String    @map("team_id") @db.Uuid
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

// ------------------------------------------------------
// RBAC (Role-Based Access Control)
// ------------------------------------------------------

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid // null for system-wide roles
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  permissions  RolePermission[]
  invitations  OrganizationInvitation[]

  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ------------------------------------------------------
// Clients & Billing
// ------------------------------------------------------

model Client {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  email          String?
  company        String?
  address        String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  invoices     Invoice[]

  @@index([organizationId])
  @@map("clients")
}

model Invoice {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  amount         Decimal   @db.Decimal(10, 2)
  status         String // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  issueDate      DateTime  @map("issue_date")
  dueDate        DateTime  @map("due_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([clientId])
  @@index([organizationId])
  @@map("invoices")
}

model Payment {
  id          String    @id @default(uuid()) @db.Uuid
  invoiceId   String    @map("invoice_id") @db.Uuid
  amount      Decimal   @db.Decimal(10, 2)
  method      String // STRIPE, PAYPAL, BANK_TRANSFER
  status      String // PENDING, COMPLETED, FAILED, REFUNDED
  paymentDate DateTime  @map("payment_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

// ------------------------------------------------------
// Projects & Tasks
// ------------------------------------------------------

model Project {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  clientId       String?   @map("client_id") @db.Uuid
  teamId         String?   @map("team_id") @db.Uuid
  name           String
  description    String?
  status         String // ACTIVE, ARCHIVED, COMPLETED, ON_HOLD
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  tasks        Task[]
  milestones   Milestone[]
  members      ProjectMember[]
  invitations  ProjectInvitation[]
  documents    Document[]
  mentorRequests MentorRequest[]
  aiMemories   AIPersonaMemory[]

  @@index([organizationId])
  @@index([clientId])
  @@index([teamId])
  @@map("projects")
}

model ProjectInvitation {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  email     String
  role      String   @default("MEMBER")
  token     String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now()) @map("created_at")
  
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@map("project_invitations")
}

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String
  description String?
  status      String // TODO, IN_PROGRESS, IN_REVIEW, DONE
  priority    String // LOW, MEDIUM, HIGH, URGENT
  assigneeId  String?   @map("assignee_id")
  milestoneId String?   @map("milestone_id") @db.Uuid
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  milestone   Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  submissions TaskSubmission[]
  comments    Comment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([milestoneId])
  @@index([status])
  @@map("tasks")
}

model TaskSubmission {
  id          String    @id @default(uuid()) @db.Uuid
  taskId      String    @map("task_id") @db.Uuid
  submitterId String    @map("submitter_id")
  content     String
  status      String // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitter User @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([submitterId])
  @@map("task_submissions")
}

// ------------------------------------------------------
// Project Management Additions
// ------------------------------------------------------

model Milestone {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String
  description String?
  status      String    // PENDING, ACTIVE, COMPLETED
  startDate   DateTime? @map("start_date")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@map("milestones")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id")
  role      String   // OWNER, ADMIN, MEMBER, VIEWER
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

// ------------------------------------------------------
// Collaboration
// ------------------------------------------------------

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  authorId  String    @map("author_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comments")
}

model Attachment {
  id         String    @id @default(uuid()) @db.Uuid
  uploaderId String    @map("uploader_id")
  entityType String    @map("entity_type") // TASK, COMMENT, PROJECT
  entityId   String    @map("entity_id") @db.Uuid
  fileUrl    String    @map("file_url")
  fileName   String    @map("file_name")
  fileSize   Int       @map("file_size") // in bytes
  fileType   String    @map("file_type") // MIME type
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  uploader   User      @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([uploaderId])
  @@map("attachments")
}

// ------------------------------------------------------
// Logs & Notifications
// ------------------------------------------------------

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id")
  type      String // MENTION, ASSIGNMENT, SYSTEM
  title     String
  message   String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

model ActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id")
  organizationId String?  @map("organization_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id")
  actorType  String   @map("actor_type") // USER, SYSTEM, API_KEY
  action     String
  resource   String
  resourceId String   @map("resource_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([resource, resourceId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ------------------------------------------------------
// Documents
// ------------------------------------------------------

model Document {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  title     String
  content   String?   @db.Text
  type      String    // PRD, Technical, Design, General
  authorId  String?   @map("author_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([authorId])
  @@map("documents")
}

// ------------------------------------------------------
// Backend Administration
// ------------------------------------------------------

model BackendAdmin {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @map("LWT_Admin_Username")
  passwordHash String   @map("LWT_Admin_Passwd")
  email        String   @unique
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("backend_admins")
}

// ------------------------------------------------------
// AI & System Logging
// ------------------------------------------------------

model AIUsageLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id")
  actionType    String   @map("action_type") // e.g., TEXT_GENERATION, IMAGE_GENERATION
  tokensUsed    Int?     @map("tokens_used")
  promptSnippet String?  @map("prompt_snippet") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model SystemErrorLog {
  id          String   @id @default(uuid()) @db.Uuid
  errorType   String   @map("error_type")
  message     String   @db.Text
  stackTrace  String?  @map("stack_trace") @db.Text
  metadata    Json?
  isResolved  Boolean  @default(false) @map("is_resolved")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([errorType])
  @@index([isResolved])
  @@index([createdAt])
  @@map("system_error_logs")
}

model AIPersonaMemory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  projectId String?  @map("project_id") @db.Uuid
  persona   String   // "PM", "HR", "TECH_LEAD"
  role      String   // "user" or "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([persona])
  @@map("ai_persona_memories")
}

// ------------------------------------------------------
// Subscriptions & Billing
// ------------------------------------------------------

model Plan {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @unique
  stripeProductId  String?  @map("stripe_product_id")
  priceMonthly     Decimal? @map("price_monthly") @db.Decimal(10,2)
  priceYearly      Decimal? @map("price_yearly") @db.Decimal(10,2)
  features         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subscriptions    Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("user_id")
  planId             String   @map("plan_id") @db.Uuid
  status             String   // ACTIVE, CANCELED, PAST_DUE
  stripeSubId        String?  @unique @map("stripe_sub_id")
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  cancelAtPeriodEnd  Boolean  @default(false) @map("cancel_at_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("subscriptions")
}

// ------------------------------------------------------
// Mentor Marketplace
// ------------------------------------------------------

model MentorProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id")
  title             String
  bio               String?  @db.Text
  skills            String[]
  yearsOfExperience Int      @map("years_of_experience")
  hourlyRate        Decimal  @map("hourly_rate") @db.Decimal(10,2)
  portfolioUrl      String?  @map("portfolio_url")
  linkedinUrl       String?  @map("linkedin_url")
  githubUrl         String?  @map("github_url")
  isVerified        Boolean  @default(false) @map("is_verified")
  approvalStatus    String   @default("PENDING") @map("approval_status") // PENDING, APPROVED, REJECTED
  rating            Decimal? @db.Decimal(3,2)
  totalReviews      Int      @default(0) @map("total_reviews")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests MentorRequest[]
  wallet   Wallet?

  @@index([approvalStatus])
  @@map("mentor_profiles")
}

model MentorRequest {
  id                String   @id @default(uuid()) @db.Uuid
  studentId         String   @map("student_id")
  mentorId          String   @map("mentor_id") @db.Uuid
  projectId         String?  @map("project_id") @db.Uuid
  problemStatement  String   @map("problem_statement") @db.Text
  requiredExpertise String[] @map("required_expertise")
  budget            Decimal  @db.Decimal(10,2)
  status            String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, COMPLETED
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  student User          @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  mentor  MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  project Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  session MentorSession?

  @@index([studentId])
  @@index([mentorId])
  @@map("mentor_requests")
}

model MentorSession {
  id          String    @id @default(uuid()) @db.Uuid
  requestId   String    @unique @map("request_id") @db.Uuid
  meetingLink String?   @map("meeting_link")
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  status      String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELED
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  request MentorRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  review  MentorReview?

  @@map("mentor_sessions")
}

model MentorReview {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @unique @map("session_id") @db.Uuid
  studentId String   @map("student_id")
  mentorId  String   @map("mentor_id")
  rating    Int
  feedback  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  session MentorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User          @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@map("mentor_reviews")
}

// ------------------------------------------------------
// Transactions & Wallets
// ------------------------------------------------------

model MentorTransaction {
  id             String   @id @default(uuid()) @db.Uuid
  studentId      String   @map("student_id")
  mentorId       String   @map("mentor_id") @db.Uuid
  amount         Decimal  @db.Decimal(10,2)
  platformFee    Decimal  @map("platform_fee") @db.Decimal(10,2)
  mentorEarnings Decimal  @map("mentor_earnings") @db.Decimal(10,2)
  status         String   // PENDING, COMPLETED, FAILED, REFUNDED
  stripePaymentId String? @unique @map("stripe_payment_id")
  createdAt      DateTime @default(now()) @map("created_at")

  student User          @relation("StudentTransactions", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([mentorId])
  @@map("mentor_transactions")
}

model Wallet {
  id          String   @id @default(uuid()) @db.Uuid
  mentorId    String   @unique @map("mentor_id") @db.Uuid
  balance     Decimal  @default(0) @db.Decimal(10,2)
  totalEarned Decimal  @default(0) @map("total_earned") @db.Decimal(10,2)
  updatedAt   DateTime @updatedAt @map("updated_at")

  mentor      MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]

  @@map("wallets")
}

model Withdrawal {
  id          String    @id @default(uuid()) @db.Uuid
  walletId    String    @map("wallet_id") @db.Uuid
  amount      Decimal   @db.Decimal(10,2)
  status      String    @default("PENDING") // PENDING, PROCESSED, FAILED
  requestedAt DateTime  @default(now()) @map("requested_at")
  processedAt DateTime? @map("processed_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("withdrawals")
}
